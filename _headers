# Cloudflare Pages 用ヘッダ（netlify.toml の [[headers]] と同等）。
# 元ファイルは一切変更せず、この _headers と functions/ だけが Cloudflare 版の追加分。

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(self), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://www.google.com https://www.gstatic.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://itunes.apple.com https://esm.sh; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' data: https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; media-src 'self' blob: https://audio-ssl.itunes.apple.com https://video-ssl.itunes.apple.com https://*.mzstatic.com; connect-src 'self' blob: https://www.google.com https://www.gstatic.com https://itunes.apple.com https://rss.applemarketingtools.com https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://*.firebasedatabase.app wss://*.firebasedatabase.app https://*.workers.dev https://content-firebaseappcheck.googleapis.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://api.mymemory.translated.net https://api.open-meteo.com https://ja.wikipedia.org https://threejs.org https://flagcdn.com https://api.song.link https://corsproxy.io https://api.allorigins.win https://esm.sh https://*.skyway.ntt.com wss://*.skyway.ntt.com; frame-src 'self' https://www.google.com https://open.spotify.com https://w.soundcloud.com https://embed.music.apple.com https://www.youtube.com https://music.youtube.com https://*.trycloudflare.com; worker-src 'self' blob: data:; manifest-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'self'

/apps/stscli.zip
  Content-Type: application/zip
  Content-Disposition: attachment; filename="StS-CLI.zip"

# spotlight / aero-leap は緩い CSP に差し替え（! で /* の値を外してから設定）
/spotlight/*
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self' https: data: blob: 'unsafe-inline' 'unsafe-eval'; img-src 'self' https: data: blob:; media-src 'self' https: data: blob:; connect-src 'self' https:; frame-ancestors 'self'; base-uri 'self'
  X-Frame-Options: SAMEORIGIN

/apps/aero-leap/*
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self' https: data: blob: 'unsafe-inline' 'unsafe-eval'; img-src 'self' https: data: blob:; media-src 'self' https: data: blob:; connect-src 'self' https:; frame-ancestors 'self'; base-uri 'self'

# SW / メインHTML は常に最新（古い版を配り続けない）
/gc-sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/app.js
  Cache-Control: no-cache

/spotlight-tpl.js
  Cache-Control: no-cache

/*.css
  Cache-Control: no-cache
